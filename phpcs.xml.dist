<?xml version="1.0"?>
<ruleset name="SymPress CLI">
    <description>
        Coding standard audit for the standalone SymPress CLI package.
    </description>

    <arg name="colors" />
    <arg name="basepath" value="." />

    <file>src</file>
    <file>tests</file>

    <exclude-pattern>vendor/*</exclude-pattern>
    <exclude-pattern>.phpunit.cache/*</exclude-pattern>

    <rule ref="PSR12" />
</ruleset>
